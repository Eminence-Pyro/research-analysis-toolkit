{
  "schema_version": "1.0",
  "variables": [
    {
      "name": "age", "label": "Age (years)",
      "distribution": "normal",
      "params": { "mean": 35, "std": 10, "min": 18, "max": 70 },
      "type": "continuous"
    },
    {
      "name": "gender", "label": "Gender",
      "distribution": "categorical",
      "params": { "Female": 0.55, "Male": 0.45 },
      "type": "categorical"
    },
    {
      "name": "education", "label": "Highest educational level",
      "distribution": "categorical",
      "params": {
        "No formal education": 0.10,
        "Primary": 0.20,
        "Secondary": 0.45,
        "Tertiary": 0.25
      },
      "type": "ordinal"
    },
    {
      "name": "distance_km", "label": "Distance to facility (km)",
      "distribution": "exponential",
      "params": { "scale": 3.0, "min": 0.5, "max": 20.0 },
      "type": "continuous"
    }
  ]
}
