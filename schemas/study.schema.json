{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rat://schemas/study.schema.json",
  "title": "Study Configuration",
  "description": "Schema for studies/*/config.json",
  "type": "object",
  "required": ["schema_version", "title", "design", "setting", "population",
               "sampling_technique", "target_n", "facilities"],
  "additionalProperties": true,
  "properties": {
    "schema_version":      { "type": "string", "enum": ["1.0"] },
    "rat_version":         { "type": "string" },
    "title":               { "type": "string", "minLength": 3 },
    "setting":             { "type": "string", "minLength": 3 },
    "population":          { "type": "string", "minLength": 3 },
    "target_n":            { "type": "integer", "minimum": 1, "maximum": 10000 },
    "design":              { "type": "string" },
    "sampling_technique":  { "type": "string" },
    "facilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": true,
        "properties": {
          "id":                   { "type": "integer", "minimum": 1 },
          "name":                 { "type": "string", "minLength": 1 },
          "ward":                 { "type": "string" },
          "lga":                  { "type": "string" },
          "state":                { "type": "string" },
          "satisfaction_effect":  { "type": "number" }
        }
      }
    }
  }
}
