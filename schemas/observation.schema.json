{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rat://schemas/observation.schema.json",
  "title": "Observation Checklist Configuration",
  "description": "Schema for studies/*/observation.json",
  "type": "object",
  "required": ["checklist"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "additionalProperties": true,
        "properties": {
          "key":    { "type": "string", "minLength": 1 },
          "label":  { "type": "string", "minLength": 1 },
          "domain": { "type": "string" }
        }
      }
    }
  }
}
