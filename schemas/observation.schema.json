{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Eminence-Pyro/research-analysis-toolkit/schemas/observation.schema.json",
  "title": "Observation Checklist Configuration",
  "description": "Schema for studies/*/observation.json",
  "type": "object",
  "required": ["schema_version", "checklist"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["variable_name", "label", "anchor", "base_probability"],
        "properties": {
          "variable_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label":         { "type": "string" },
          "anchor": {
            "type": "string",
            "enum": ["environment", "service"],
            "description": "Links observation to satisfaction section for consistency checks"
          },
          "base_probability": {
            "type": "number", "minimum": 0.0, "maximum": 1.0
          },
          "distance_sensitive": { "type": "boolean" }
        }
      }
    }
  }
}
