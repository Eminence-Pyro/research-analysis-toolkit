{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Eminence-Pyro/research-analysis-toolkit/schemas/demographics.schema.json",
  "title": "Demographics Configuration",
  "description": "Schema for studies/*/demographics.json",
  "type": "object",
  "required": ["schema_version", "variables"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "distribution", "params", "type"],
        "properties": {
          "name":  { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" },
          "distribution": {
            "type": "string",
            "enum": ["normal", "exponential", "categorical", "uniform"]
          },
          "params": { "type": "object" },
          "type": {
            "type": "string",
            "enum": ["continuous", "categorical", "ordinal", "integer"]
          }
        }
      }
    }
  }
}
