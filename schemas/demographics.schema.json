{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rat://schemas/demographics.schema.json",
  "title": "Demographics Configuration",
  "description": "Schema for studies/*/demographics.json — flat field-keyed object",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "oneOf": [
      {
        "title": "Categorical distribution",
        "type": "object",
        "description": "Keys are category labels, values are proportions (0–1). Sum should be ~1.",
        "minProperties": 2,
        "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      {
        "title": "Continuous distribution",
        "type": "object",
        "required": ["distribution"],
        "additionalProperties": true,
        "properties": {
          "distribution": {
            "type": "string",
            "enum": ["normal", "uniform", "exponential", "lognormal"]
          },
          "mean":  { "type": "number" },
          "std":   { "type": "number", "minimum": 0 },
          "min":   { "type": "number" },
          "max":   { "type": "number" },
          "scale": { "type": "number", "minimum": 0 }
        }
      }
    ]
  }
}
