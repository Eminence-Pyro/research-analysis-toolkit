{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rat://schemas/questionnaire.schema.json",
  "title": "Questionnaire Configuration",
  "description": "Schema for studies/*/questionnaire.json",
  "type": "object",
  "required": ["schema_version", "title", "sections"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "title":          { "type": "string", "minLength": 3 },
    "scale": {
      "type": "object",
      "description": "Optional Likert scale label map — e.g. {'1': 'Very Dissatisfied', '5': 'Very Satisfied'}"
    },
    "sections": {
      "type": "object",
      "minProperties": 1,
      "description": "Keys are section letters (A, B, ...). Each value is a section definition.",
      "additionalProperties": {
        "type": "object",
        "required": ["title", "items"],
        "properties": {
          "title": { "type": "string", "minLength": 3 },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
