{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Eminence-Pyro/research-analysis-toolkit/schemas/questionnaire.schema.json",
  "title": "Questionnaire Configuration",
  "description": "Schema for studies/*/questionnaire.json",
  "type": "object",
  "required": ["schema_version", "title", "sections"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "title":          { "type": "string" },
    "sections": {
      "type": "object",
      "description": "Map of section key (A, B, ...) to section definition",
      "additionalProperties": {
        "type": "object",
        "required": ["title", "items"],
        "properties": {
          "title":     { "type": "string" },
          "construct": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["number", "variable_name", "text", "scale"],
              "properties": {
                "number":        { "type": "string" },
                "variable_name": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$",
                  "description": "Snake_case variable name — used as column header"
                },
                "text":  { "type": "string", "minLength": 5 },
                "scale": { "type": "string", "enum": ["Likert5", "Likert4", "Likert3"] }
              }
            }
          }
        }
      }
    }
  }
}
